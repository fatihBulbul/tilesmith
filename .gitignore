# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
!studio/frontend/dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Plugin data (generated at runtime)
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm
output/
*.tmx
*.tsx
!skills/**/*.tmx
!skills/**/*.tsx

# Plugin packaging output
*.plugin
*.zip

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Studio frontend build output
# NOTE: studio/frontend/dist/ IS committed so the plugin ships with a
# ready-to-use Studio build. Users don't need Node.js installed.
# Regenerate with `cd studio/frontend && npm run build` before release.
studio/frontend/node_modules/

# Session-specific handoff notes (not for public repo)
docs/NEXT_SESSION.md

# Tileset packs (third-party, users supply their own)
assets/
tilesets/
packs/
ERW*/
*.png
!docs/**/*.png
!.github/**/*.png

# Studio frontend build artifacts — these must ship with the plugin so
# users don't need Node installed. The negations re-include them even
# though the generic `assets/` and `dist/` rules above would otherwise
# swallow them.
!studio/frontend/dist/
!studio/frontend/dist/**
!studio/frontend/dist/assets/
!studio/frontend/dist/assets/*.js
